# Copie este arquivo para .env e preencha os valores

# ========================================================
# BANCO DE DADOS (obrigatório)
# ========================================================
DB_URL=jdbc:mysql://localhost:3306/festasdb?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=sua_senha_aqui

# ========================================================
# JWT (obrigatório — use um segredo forte, mínimo 32 chars)
# ========================================================
JWT_SECRET=gere-um-segredo-forte-e-unico-aqui-com-pelo-menos-64-caracteres

# ========================================================
# CORS (origens permitidas separadas por vírgula)
# ========================================================
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ========================================================
# ADMIN PADRÃO (criado na primeira execução)
# ========================================================
ADMIN_EMAIL=admin@festas.com
ADMIN_PASSWORD=troque-essa-senha-imediatamente
